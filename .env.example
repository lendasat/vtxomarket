# Ark server configuration
# Mutinynet (testnet — 30s blocks, free faucet at https://faucet.mutinynet.com)
NEXT_PUBLIC_ARK_SERVER_URL=https://mutinynet.arkade.sh
NEXT_PUBLIC_ESPLORA_URL=https://mutinynet.com/api
NEXT_PUBLIC_BOLTZ_URL=https://api.boltz.mutinynet.arkade.sh

# Introspector (Arkade Script opcode validation — gRPC on port 7073)
# Not yet publicly hosted on mutinynet — run locally via introspector/
NEXT_PUBLIC_INTROSPECTOR_URL=http://localhost:7073

