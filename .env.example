# Ark server configuration
# Mutinynet (testnet — 30s blocks, free faucet at https://faucet.mutinynet.com)
NEXT_PUBLIC_ARK_SERVER_URL=https://mutinynet.arkade.sh
NEXT_PUBLIC_ESPLORA_URL=https://mutinynet.com/api
NEXT_PUBLIC_BOLTZ_URL=https://api.boltz.mutinynet.arkade.sh

# Asset Indexer (Bun + SQLite + Hono — see indexer/)
NEXT_PUBLIC_INDEXER_URL=http://localhost:3001

# Introspector (Arkade Script opcode validation — required for swaps)
# Clone from https://github.com/ArkLabsHQ/introspector and run locally
NEXT_PUBLIC_INTROSPECTOR_URL=http://localhost:7073

# LendaSwap (atomic swaps between BTC/Arkade and EVM stablecoins)
NEXT_PUBLIC_LENDASWAP_API_URL=https://api.lendaswap.com/
NEXT_PUBLIC_LENDASWAP_API_KEY=

# Mainnet
# NEXT_PUBLIC_ARK_SERVER_URL=https://arkade.computer
# NEXT_PUBLIC_ESPLORA_URL=https://mempool.space/api
# NEXT_PUBLIC_BOLTZ_URL=https://api.ark.boltz.exchange
