# ── Introspector ────────────────────────────────────────────────────────────────
# Validates Arkade Script introspection conditions and co-signs swap PSBTs.
# Docs: https://github.com/ArkLabsHQ/introspector

# Private key for signing (hex-encoded, 32 bytes).
# Generate one with: openssl rand -hex 32
# IMPORTANT: Once set, do NOT change — the public key derived from this is
# baked into existing swap scripts. Changing it breaks open offers.
INTROSPECTOR_SECRET_KEY=

# Disable TLS (use true when behind a reverse proxy that terminates TLS)
INTROSPECTOR_NO_TLS=true

# gRPC + REST gateway port (REST is what the frontend uses)
INTROSPECTOR_PORT=7073

# Log verbosity (0=panic, 1=fatal, 2=error, 3=warn, 4=info, 5=debug, 6=trace)
INTROSPECTOR_LOG_LEVEL=4

# Data directory (inside the container)
INTROSPECTOR_DATADIR=/app/data
