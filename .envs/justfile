# Switch environment: just -f .envs/justfile mutinynet

set working-directory := ".."

mutinynet:
    sops -d --input-type dotenv --output-type dotenv .envs/mutinynet > .env
    sops -d --input-type dotenv --output-type dotenv .envs/indexer.mutinynet > interim_asset_indexer/.env
    @echo "Switched to mutinynet"

# Show decrypted env (stdout only, doesn't write files)
show file:
    sops -d --input-type dotenv --output-type dotenv .envs/{{file}}

# Edit an encrypted env file
edit file:
    sops --input-type dotenv --output-type dotenv .envs/{{file}}

current:
    @grep NEXT_PUBLIC_ARK_SERVER_URL .env 2>/dev/null | sed 's/.*\/\///' | sed 's/\..*//' || echo "unknown"
