# ── Ark Server ──────────────────────────────────────────────────────────────────
# URL of the arkd instance to index. Determines which network is indexed.
# Mainnet:   https://arkade.computer
# Mutinynet: https://mutinynet.arkade.sh
ARK_SERVER_URL=https://mutinynet.arkade.sh

# Human-readable network label (for logs / API responses)
NETWORK=mutinynet

# ── Service ──────────────────────────────────────────────────────────────────────
PORT=3001
LOG_LEVEL=info   # debug | info | warn | error

# ── Storage ──────────────────────────────────────────────────────────────────────
DATABASE_PATH=./data/indexer.db

# ── Behaviour ────────────────────────────────────────────────────────────────────
# How long (ms) to wait before reconnecting the SSE stream after a disconnect
SSE_RECONNECT_DELAY_MS=3000

# How many outpoints to batch in a single /v1/indexer/vtxos request
OUTPOINT_BATCH_SIZE=50
