# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# service worker build artifact (rebuilt by npm run build:worker)
public/wallet-service-worker.mjs

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (plaintext — never commit)
.env*
!.env.example
!.env.indexer.example
!.env.introspector.example

# SOPS encrypted env files
.envs/
.sops.yaml

# external repos (clone separately — see README)
introspector/
arkade-ts-sdk/

# test/scratch pages
src/app/test-ark/

# indexer data
indexer/data/

# firebase
firebase-debug.log

# vercel
.vercel

# opennext / cloudflare build artifacts
/.open-next/

# typescript
*.tsbuildinfo
next-env.d.ts
